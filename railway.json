{
  "$schema": "https://railway.app/railway.schema.json",
  "build": {
    "builder": "dockerfile",
    "dockerfile": "Dockerfile"
  },
  "deploy": {
    "startCommand": "sh -c 'OPENCLAW_GATEWAY_PORT=${PORT:-18789} node openclaw.mjs gateway'",
    "restartPolicyMaxRetries": 5,
    "restartPolicyWindowMs": 60000,
    "healthchecks": {
      "readiness": "/readyz",
      "liveness": "/healthz"
    }
  }
}
